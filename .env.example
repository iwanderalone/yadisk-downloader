# OAuth-токен Яндекс 360 / Яндекс Диск (должен иметь право cloud_api:disk.read)
YANDEX_OAUTH_TOKEN=your_yandex_oauth_token

# Метка общего диска (vd_hash), находится в URL Яндекс Диска после vd/
YANDEX_VD_HASH=your_yandex_shared_disk_hash
YANDEX_FILE_PATH=table.xlsx

# Токен Telegram бота
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram ID администратора для получения фидбека (необязательно, по умолчанию: 791647629)
ADMIN_TELEGRAM_ID=791647629
